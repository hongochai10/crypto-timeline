{
  "name": "crypto-timeline-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build",
    "build:stats": "next build 2>&1 | tee .next/build-stats.txt",
    "e2e": "playwright test",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:webkit": "playwright test --project=webkit",
    "e2e:update-snapshots": "CI_USE_BUILD=1 playwright test src/e2e/visual-regression.spec.ts --update-snapshots=all"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@serwist/next": "^9.5.7",
    "@swc/helpers": "^0.5.20",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^18",
    "react-dom": "^18",
    "serwist": "^9.5.7",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^6",
    "vitest": "^4.1.1"
  }
}
